                FROM appointments a
                JOIN schedules s ON s.schedule_id = a.schedule_id
                JOIN doctors   d ON d.doctor_id   = a.doctor_id
                WHERE a.status = 'scheduled'
                  AND a.reminder_24h_sent = false
